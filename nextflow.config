/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Flomics/fl-kraken Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    // ── Input / output ────────────────────────────────────────────────────────
    // Two-column TSV: <accession_id>  <dataset_batch>
    input                    = null
    outdir                   = './results'
    publish_dir_mode         = 'copy'

    // ── Kraken2 classification ────────────────────────────────────────────────
    kraken2_db               = 's3://flomics-no-backup/references/Genomes/KrakenDB/k2_pluspf_20230314.tar.gz'
    phylo_kraken_full_report = true

    // ── Auxiliary files for download strategies ───────────────────────────────
    // Default paths point to the bundled k2_reprocessing/ directory.
    // Override via --param /absolute/path if your files are elsewhere.
    //
    // Used by strategy:
    //   sra_run_table         → SRRISOLATE  (maps isolate IDs to SRR runs)
    //   isolate_to_runs       → X-series    (maps integer isolate IDs to SRR runs)
    //   ena_prjeb90290_tsv    → SAMP*       (ENA FTP URL table for PRJEB90290)
    //   ega_files_csv         → RNA*        (EGA file ID mapping)
    //   ega_credentials       → RNA*        (pyega3 credentials.json)

    sra_run_table         = "${projectDir}/k2_reprocessing/SraRunTable.csv"
    isolate_to_runs       = "${projectDir}/k2_reprocessing/isolate_to_runs.txt"
    ena_prjeb90290_tsv    = "${projectDir}/k2_reprocessing/ena_prjeb90290.tsv"
    ega_files_csv         = "${projectDir}/k2_reprocessing/ega_files.tsv"
    ega_credentials       = "${projectDir}/k2_reprocessing/credentials.json"

    // ── Display ───────────────────────────────────────────────────────────────
    monochrome_logs          = false

    // ── Resource limits ───────────────────────────────────────────────────────
    max_memory               = '128.GB'
    max_cpus                 = 16
    max_time                 = '240.h'
}

// Load base process resource config
includeConfig 'conf/base.config'

// Load module-specific publishDir config
includeConfig 'conf/modules.config'

profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
        conda.enabled          = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
    }
    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
    }
}

// Wave — auto-builds containers from conda environment.yml files.
// Required for DOWNLOAD_SAMPLE and TRIM_SAMPLE which have no pre-built image.
wave {
    enabled = true
    strategy = 'conda,container'  // prefer conda env over container directive
}

// Manifest
manifest {
    name            = 'Flomics/fl-kraken'
    description     = 'Download → trim → Kraken2 + Krona phylogenetic classification pipeline'
    nextflowVersion = '!>=22.10.0'
    version         = '1.0.0'
}

// Function to check max resource limits
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}
