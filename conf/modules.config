/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    withName: 'DOWNLOAD_SAMPLE' {
        publishDir = [
            enabled: false   // raw downloads are intermediate; not published
        ]
    }

    withName: 'UMITOOLS_EXTRACT' {
        // UMI pattern: 8 nt UMI + 6 nt discard at 5' end of R1
        ext.args = '--extract-method=regex --bc-pattern=\'^(?P<umi_1>.{8})(?P<discard_1>.{6}).*\''
        publishDir = [
            path: { "${params.outdir}/trimming/${meta.id}" },
            pattern: '*.log',
            mode: params.publish_dir_mode
        ]
    }

    withName: 'TRIMGALORE' {
        // Dataset-specific Trim Galore arguments.
        // Normalise the dataset label (lowercase, collapse separators) then select args.
        ext.args = {
            def ADAPTER_ARGS = "--fastqc -a AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC -a2 AGATCGGAAGAGCGTCGTGTAGGGAAAGAGTGT --stringency 20 --length 20"

            def norm = (meta.dataset ?: '').toLowerCase()
                .replaceAll(/[ ()\-,]/, '_')
                .replaceAll(/_+/, '_')
                .replaceAll(/^_|_$/, '')

            // Base trimming arguments per dataset
            def base_args
            if      (norm ==~ /block.*|chen|moufarrej.*|ngo|roskams.*|sun_?[12]|tao|zhu|encode/) { base_args = ADAPTER_ARGS }
            else if (norm ==~ /decruyenaere|flomics_?[12]/)                                       { base_args = ADAPTER_ARGS }
            else if (norm ==~ /chalasani|giraldez.*|ibarra.*|reggiardo.*|toden|wang|wei|rozowsky/) { base_args = '--fastqc'  }
            else    { throw new IllegalArgumentException("TRIMGALORE: unknown dataset '${meta.dataset}' (normalized: '${norm}'). Add it to conf/modules.config.") }

            // Two-color Illumina chemistry (NextSeq/NovaSeq): suppress polyG tails
            def two_color = norm ==~ /block.*|chalasani|decruyenaere|flomics_?2|giraldez.*|ibarra.*|moufarrej.*|ngo|reggiardo.*|toden|wang/
            two_color ? "${base_args} --nextseq 20" : base_args
        }
        publishDir = [
            [
                path: { "${params.outdir}/trimming/${meta.id}" },
                pattern: '*.{html,zip}',
                mode: params.publish_dir_mode
            ],
            [
                path: { "${params.outdir}/trimming/${meta.id}" },
                pattern: '*_trimming_report.txt',
                mode: params.publish_dir_mode
            ]
        ]
    }

    withName: 'KRAKEN2' {
        publishDir = [
            path: { "${params.outdir}/Flomics_Phylo" },
            pattern: '*.{txt,gz}',
            mode: params.publish_dir_mode
        ]
    }

    withName: 'KRONA_KTIMPORTTAXONOMY' {
        ext.args = '-t 5 -m 3'
        publishDir = [
            path: { "${params.outdir}/Flomics_Phylo" },
            pattern: '*.html',
            mode: params.publish_dir_mode
        ]
    }

    withName: 'UNTAR_KRAKEN2_DB' {
        publishDir = [
            enabled: false
        ]
    }

    withName: 'KRONA_KTUPDATETAXONOMY' {
        publishDir = [
            enabled: false
        ]
    }

}
